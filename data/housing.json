<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Аренда жилья - HESS Marketplace</title>
<style>
body { margin:0; font-family:Arial,sans-serif; background:#0d0d0d; color:white; }
.header { padding:15px; background:rgba(0,0,0,0.7); text-align:center; font-size:24px; font-weight:bold; }
.housing-list { display:grid; grid-template-columns:1fr 1fr; gap:15px; padding:15px; }
.housing-card { background:rgba(255,255,255,0.1); border-radius:15px; overflow:hidden; text-align:center; cursor:pointer; transition:0.2s; }
.housing-card img { width:100%; height:150px; object-fit:cover; }
.housing-card h3 { margin:10px 0 5px; }
.housing-card p { margin:0 0 10px; }
.housing-card a { display:inline-block; margin-bottom:10px; padding:5px 10px; background:#1e90ff; color:white; border-radius:10px; text-decoration:none; transition:0.2s; }
.housing-card a:hover { background:#0a70d1; }
#add-form { padding:15px; margin:15px; background:rgba(255,255,255,0.1); border-radius:15px; }
#add-form input { display:block; width:100%; margin-bottom:10px; padding:8px; border-radius:8px; border:none; }
#add-form button { padding:10px 15px; border:none; border-radius:8px; background:#1e90ff; color:white; cursor:pointer; }
#add-form button:hover { background:#0a70d1; }
</style>
</head>
<body>

<div class="header">Аренда жилья</div>

<!-- Форма добавления нового объявления -->
<div id="add-form">
  <h3>Добавить объявление</h3>
  <input type="text" id="title" placeholder="Название">
  <input type="text" id="price" placeholder="Цена">
  <input type="text" id="image" placeholder="Ссылка на изображение">
  <input type="text" id="link" placeholder="Ссылка 'Подробнее'">
  <button onclick="addHousing()">Добавить</button>
</div>

<div class="housing-list" id="housing-list"></div>

<script>
let housingData = [];

// Загружаем исходные данные из JSON + LocalStorage
async function loadHousing() {
  try {
    // JSON с исходными объявлениями
    const response = await fetch('data/housing.json');
    const initialData = await response.json();

    // Загружаем дополнительно из LocalStorage
    const savedData = JSON.parse(localStorage.getItem('housingLocal')) || [];

    housingData = initialData.concat(savedData);
    renderHousing();
  } catch (err) {
    console.error('Ошибка загрузки housing.json:', err);
  }
}

// Отрисовка карточек
function renderHousing() {
  const container = document.getElementById('housing-list');
  container.innerHTML = '';
  housingData.forEach(item => {
    const card = document.createElement('div');
    card.className = 'housing-card';
    card.innerHTML = `
      <img src="${item.image}" alt="${item.title}">
      <h3>${item.title}</h3>
      <p>Цена: ${item.price}</p>
      <a href="${item.link}">Подробнее</a>
    `;
    container.appendChild(card);
  });
}

// Добавление нового объявления
function addHousing() {
  const title = document.getElementById('title').value.trim();
  const price = document.getElementById('price').value.trim();
  const image = document.getElementById('image').value.trim();
  const link = document.getElementById('link').value.trim();

  if(!title || !price || !image || !link) {
    alert('Заполните все поля!');
    return;
  }

  const newItem = { title, price, image, link };
  housingData.push(newItem);

  // Сохраняем только пользовательские объявления в LocalStorage
  const savedData = JSON.parse(localStorage.getItem('housingLocal')) || [];
  savedData.push(newItem);
  localStorage.setItem('housingLocal', JSON.stringify(savedData));

  // Очистка формы
  document.getElementById('title').value = '';
  document.getElementById('price').value = '';
  document.getElementById('image').value = '';
  document.getElementById('link').value = '';

  renderHousing();
}

loadHousing();
</script>

</body>
</html>